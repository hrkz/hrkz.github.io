---
import Page from "../components/Page.astro";
import "../style/typo.scss";

const { frontmatter } = Astro.props;
---

<Page page={frontmatter.title} , site="Simulating Nature">
  <div class="container">
    <section class="article__frontmatter">
      <h2><b>{frontmatter.title}</b></h2>
      <div>
        <label
          ><i>{frontmatter.pubDate.toDateString()}</i> · {
            frontmatter.tags.join(" | ")
          }</label
        >
      </div>
      <div>
        <label>by <a href="#">{frontmatter.author}</a></label>
      </div>
    </section>
    <hr />
    <article class="article__content">
      <slot />
    </article>
  </div>
</Page>

<style>
  :global(header) {
    position: absolute;
  }

  .article__frontmatter {
    margin-block: 1em;
  }
</style>
