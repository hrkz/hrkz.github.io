---
const { id, frontmatter } = Astro.props;
---

<li>
  <div class="note-entry">
    <h4><a href={`/notes/${id}`}><b>{frontmatter.title}</b></a></h4>
    <div class="note-entry__frontmatter">
      <label
        ><i>{frontmatter.pubDate.toDateString()}</i> · {
          frontmatter.tags.join(" | ")
        }</label
      >
    </div>
    <span>{frontmatter.description}</span>
    <div>
      <label>by <a href="#">{frontmatter.author}</a></label>
    </div>
  </div>
  <hr />
</li>

<style>
  .note-entry {
    padding-block: calc(0.15 * var(--base-size));

    .note-entry__frontmatter {
      display: flex;
      align-items: center;
      margin-bottom: calc(0.05 * var(--base-size));
    }
  }
</style>
